# IMPORTANT: Generate strong random secrets for production
# Use: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-this-to-a-strong-random-secret-at-least-64-characters-long
JWT_REFRESH_SECRET=change-this-to-a-different-strong-random-secret-at-least-64-characters-long
JWT_EXPIRE=7d
JWT_REFRESH_EXPIRE=30d
NODE_ENV=development
DB_DIALECT=sqlite
DB_PATH=database.sqlite
